{
	"compilerOptions": {
		"lib": ["es2022"],
		"target": "es2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"removeComments": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": ["nodes/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
